# CampusConnect 360 — Variables de entorno de ejemplo.
# Copia este archivo a `.env` y ajusta los valores. NO subas `.env` al repositorio.

# --- RabbitMQ ---
RABBITMQ_USER=campus
RABBITMQ_PASS=campus123

# --- PostgreSQL ---
POSTGRES_USER=campus
POSTGRES_PASSWORD=campus123

# --- Seguridad / JWT (usar mínimo 32 caracteres en el secreto) ---
JWT_SECRET=cambia-esto-por-un-secreto-largo-de-al-menos-32-caracteres
JWT_EXPIRATION=3600
